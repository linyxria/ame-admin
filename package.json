{
  "name": "ame-admin",
  "private": true,
  "type": "module",
  "workspaces": ["server", "web"],
  "scripts": {
    "dev:server": "bun --filter @ame-admin/server dev",
    "dev:web": "bun --filter @ame-admin/web dev",
    "build:web": "bun --filter @ame-admin/web build",
    "typecheck:server": "bun --filter @ame-admin/server typecheck",
    "db:up": "bun --filter @ame-admin/server db:up",
    "db:down": "bun --filter @ame-admin/server db:down",
    "db:setup": "bun --filter @ame-admin/server db:setup",
    "test": "bun --filter @ame-admin/server test",
    "lint": "biome lint server web",
    "format": "biome format --write server web",
    "check": "biome check server web",
    "check:write": "biome check --write server web"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.13"
  }
}
