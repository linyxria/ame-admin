{
  "name": "ame-admin-api",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f db",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/scripts/seed-admin.ts",
    "db:setup": "bun run db:migrate && bun run db:seed",
    "db:studio": "drizzle-kit studio",
    "lint": "bun run --cwd .. lint",
    "format": "bun run --cwd .. format",
    "check": "bun run --cwd .. check",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "better-auth": "^1.6.9",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "elysia": "latest",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  },
  "module": "src/index.js"
}
